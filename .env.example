# Eventbrite API Configuration
# Get API key at: https://www.eventbrite.com/platform/api-keys

# Required for fetching events
EVENTBRITE_API_KEY=

# Required for auto-RSVP (grabbing tickets)
EVENTBRITE_USER_EMAIL=
EVENTBRITE_USER_NAME=

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/command_center
