# Eventbrite API Configuration
# Get API key at: https://www.eventbrite.com/platform/api-keys

# Required for fetching events
EVENTBRITE_API_KEY=

# Required for auto-RSVP (grabbing tickets)
EVENTBRITE_USER_EMAIL=
EVENTBRITE_USER_NAME=

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/command_center

# AI Configuration (Optional - uses smart fallback if not set)
# OpenClaw uses bailian/qwen3.5-plus by default
# You can configure the same provider here for subagent chat

# For Qwen (Alibaba Cloud - same as OpenClaw default)
# AI_API_KEY=your-qwen-key
# AI_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# AI_MODEL=qwen-plus

# For OpenAI
# AI_API_KEY=your-openai-key
# AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-4

# NOTE: Without AI_API_KEY, subagents use smart contextual fallback
# (knows your memory but responses are generated from code logic)
